        "scope" : "#/properties/model/properties/trainingAttributes/properties/fingerprintColumn",
        "options" : {
          "format" : "dropDown"
        },
        "providedOptions" : [ "possibleValues" ],
        "rule" : {
          "effect" : "SHOW",
          "condition" : {
            "scope" : "#/properties/model/properties/trainingAttributes/properties/trainingAttributesMode",
            "schema" : {
              "oneOf" : [ {
                "const" : "FINGERPRINT"
              } ]
